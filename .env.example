# PayFast checkout configuration.
#
# Without any of this set, checkout runs against PayFast's public
# SANDBOX test environment (no real money moves) — the site works out
# of the box for testing.
#
# To go live, once you have a PayFast sole trader account approved:
#   1. Log in to payfast.co.za -> Settings -> Integration to find your
#      Merchant ID and Merchant Key (and set a Passphrase there too,
#      recommended).
#   2. For local development, copy this file to .env.local and fill in
#      the values below (that file is gitignored, it never gets
#      committed).
#   3. For the live deployed site, add the same values as GitHub repo
#      secrets instead (Settings > Secrets and variables > Actions):
#        PAYFAST_MERCHANT_ID, PAYFAST_MERCHANT_KEY, PAYFAST_PASSPHRASE
#      and a repo *variable* (not secret) PAYFAST_MODE = live.
#      The deploy workflow (.github/workflows/deploy.yml) already reads
#      these at build time — no code changes needed to go live.

# "sandbox" (default, test payments only) or "live"
VITE_PAYFAST_MODE=sandbox

VITE_PAYFAST_MERCHANT_ID=
VITE_PAYFAST_MERCHANT_KEY=
VITE_PAYFAST_PASSPHRASE=
